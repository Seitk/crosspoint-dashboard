# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/.wrangler/
/outputs/
/work/

# nested firmware fork clone (its own git repo — build it there, not part of this repo)
/firmware/crosspoint-reader/

# playwright / verification artifacts
/.playwright-mcp/
/x3-*.png

# local planning / design docs — kept on disk, not pushed
/docs/superpowers/
